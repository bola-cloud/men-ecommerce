{
  "permissions": {
    "allow": [
      "Bash(npx playwright *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash tests-e2e/scripts/post-test-hook.sh",
            "timeout": 15,
            "statusMessage": "AI Healing Pipeline — scanning Playwright results..."
          }
        ]
      }
    ]
  }
}
